# CoRegula Core API Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL Database
DATABASE_URL="postgresql://postgres:123hshi@localhost:5432/kolabri-db?schema=public"

# MongoDB (for chat logs, activity logs)
MONGODB_URL="mongodb://localhost:27017/coregula"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# AI Engine URL (FastAPI service)
AI_ENGINE_URL="http://localhost:8000"

# Client App URL (for CORS)
CLIENT_URL="http://localhost:8080"

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="./uploads"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Redis (optional, for production scalability)
# REDIS_URL="redis://localhost:6379"
